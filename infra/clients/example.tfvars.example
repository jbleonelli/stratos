# Copy to clients/<env>.tfvars and fill. Real *.tfvars are gitignored.
environment            = "dev"
region                 = "us-east-1"
domain                 = "" # e.g. dev.stratos.example (requires acm_certificate_arn)
acm_certificate_arn    = "" # ACM cert in us-east-1 for `domain`
vpc_cidr               = "10.20.0.0/16"
db_min_capacity        = "0.5"
db_max_capacity        = "4"
db_deletion_protection = false
enable_edge            = true                                       # S3+CloudFront+WAF SPA tier; false = backend only
enable_nat             = false                                      # true to give the agent worker internet egress (AppSync push, Bedrock)
bedrock_model_id       = "us.anthropic.claude-3-5-sonnet-20241022-v2:0" # account must have model access enabled
