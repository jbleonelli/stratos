{
  "name": "stratos-web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5173",
    "dev:stratos": "VITE_STRATOS_NATIVE=1 vite --host 127.0.0.1 --port 5173",
    "dev:e2e": "VITE_STRATOS_NATIVE=1 VITE_E2E=1 vite --host 127.0.0.1 --port 5173",
    "sync:merlin-vendor": "node scripts/sync-merlin-vendor.mjs",
    "typecheck": "tsc --noEmit",
    "build": "tsc --noEmit && vite build",
    "check:routes": "node scripts/route-map-check.mjs",
    "test:e2e": "playwright test",
    "test:visual": "playwright test --config=playwright.visual.config.ts",
    "test:visual:update": "playwright test --config=playwright.visual.config.ts --update-snapshots",
    "preview": "vite preview"
  },
  "dependencies": {
    "@aws-amplify/ui-react": "^6.5.5",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@sentry/react": "^8.50.0",
    "@supabase/supabase-js": "^2.108.2",
    "@tanstack/react-query": "^5.59.0",
    "aws-amplify": "^6.6.0",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.4",
    "remark-gfm": "^4.0.1",
    "three": "^0.170.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.170.0",
    "@vitejs/plugin-react": "^4.3.2",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
