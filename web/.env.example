# Copy to .env.local and fill from `terraform output` (infra/). Vite exposes only
# VITE_*-prefixed vars to the client.
VITE_AWS_REGION=us-east-1
VITE_USER_POOL_ID=            # terraform output cognito_user_pool_id
VITE_USER_POOL_CLIENT_ID=     # terraform output cognito_user_pool_client_id
VITE_GRAPHQL_URL=             # terraform output graphql_url
